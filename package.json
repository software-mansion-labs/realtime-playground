{
  "name": "realtime-playground",
  "private": true,
  "packageManager": "yarn@4.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "yarn workspace @realtime-playground/next run dev",
    "ios": "yarn workspace @realtime-playground/expo run ios",
    "android": "yarn workspace @realtime-playground/expo run android",
    "dev": "concurrently \"yarn web\" \"yarn ios\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "yarn workspaces foreach -Api --include '@realtime-playground/*' run lint",
    "typecheck": "yarn workspaces foreach -Api --include '@realtime-playground/*' run typecheck"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.100.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
